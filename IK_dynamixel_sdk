    target_shift_right = shift_r
    target_x_left = x_l
    target_x_right = x_r
    time.sleep(delay)

def swing_trajectory_right(duration):
    steps = 50
    dt = duration / steps
    for i in range(steps + 1):
        t = i / float(steps)
        
        # 1. Forward Progression
        x_r = 0.00 + t * 0.12
        
        # 2. Sagittal Forward Lean
        x_l = 0.00 - t * 0.03
        
        # 3. Foot Height Arc
        x_ankle = -3.0 + 12.0 * t
        raw_ankle = ((x_ankle - 9.0) ** 2) * (x_ankle + 3.0)
        h_bump = -0.00015625 * raw_ankle
        h_linear = 0.15 + t * (0.185 - 0.15)
        h_r = h_linear - 0.05*math.sin(math.pi * t)
        
        # 4. Lateral Stance
        com_lateral_sway = 0.03 * math.sin(math.pi * t)
        shift_l = 0.30  
        shift_r = (0.45 - t* 0.05) + com_lateral_sway
        
        # 5. COM Frontal Plane Trajectory
        x_com = 2.0 + 2.0 * t
        com_bump = 0.015625 * ((x_com - 4.0) ** 2) * (x_com - 2.0)
        h_l = 0.22 + 0.5*com_bump
        
        set_targets(h_l, h_r, shift_l, shift_r, x_l, x_r, dt)

def swing_trajectory_left(duration):
    steps = 50
    dt = duration / steps
    for i in range(steps + 1):
        t = i / float(steps)
        
        # 1. Forward Progression
        x_l = -0.035 + t * 0.24
        
        # 2. Sagittal Forward Lean
        x_r = -0.10 - t * 0.03
        
        # 3. Foot Height Arc
        x_ankle = -3.0 + 12.0 * t
        raw_ankle = ((x_ankle - 9.0) ** 2) * (x_ankle + 3.0)
        h_bump = -0.00015625 * raw_ankle
        h_linear = 0.14 + t * (0.19 - 0.14)
        h_l = h_linear + h_bump
        
        # 4. Lateral Stance
        com_lateral_sway = 0.03 * math.sin(math.pi * t)
        shift_r = -0.30  
        shift_l = (-0.40 + t* 0.02) + com_lateral_sway
        
        # 5. COM Frontal Plane Trajectory
        x_com = 2.0 + 2.0 * t
        com_bump = 0.015625 * ((x_com - 4.0) ** 2) * (x_com - 2.0)
        h_r = 0.22 + com_bump
        
        set_targets(h_l, h_r, shift_l, shift_r, x_l, x_r, dt)

