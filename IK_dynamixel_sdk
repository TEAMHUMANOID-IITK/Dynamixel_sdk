        la = lh_ankle

        # ROLL CALCULATIONS (Parallelogram Fix)
        HIP_ROLL_GAIN = 1.0
        ANKLE_ROLL_GAIN = -1.0
        left_roll = -HIP_ROLL_GAIN * current_shift_left
        right_roll = -HIP_ROLL_GAIN * current_shift_right
        left_ankle_roll = ANKLE_ROLL_GAIN * current_shift_left
